{
  "name": "@ash2k5/cinematic-ds",
  "version": "0.1.0",
  "description": "Cinematic Editorial design system: tokens, theming, fonts, and React components.",
  "type": "module",
  "license": "UNLICENSED",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "tokens",
    "scripts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./preset.css": "./dist/preset.css",
    "./fonts.css": "./dist/fonts.css",
    "./recipes.css": "./dist/recipes.css",
    "./theme-toggle.js": "./dist/theme-toggle.js"
  },
  "scripts": {
    "build:tokens": "node scripts/build-tokens.mjs",
    "build:lib": "tsup && node scripts/add-use-client.mjs",
    "build": "npm run build:tokens && npm run build:lib",
    "dev": "npm --workspace styleguide run dev",
    "styleguide": "npm --workspace styleguide run dev",
    "styleguide:build": "npm run build && npm --workspace styleguide run build",
    "styleguide:start": "npm --workspace styleguide run start",
    "prepublishOnly": "npm run build",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ash2k5/design-system.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.469.0",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "workspaces": [
    "styleguide"
  ]
}
